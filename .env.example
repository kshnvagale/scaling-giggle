# Copy this file to `.env` and fill in real values.
# The real `.env` is gitignored — never commit it.

# Your Anthropic API key — get it from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Your CourseForge Author agent ID — find it in the Managed Agents tab, shown
# under the agent name (looks like `agent_01...`)
COURSEFORGE_AGENT_ID=agent_...

# OPTIONAL — pin a specific environment instead of auto-picking the first one.
# Find environment IDs in the Managed Agents UI (Environments tab).
COURSEFORGE_ENVIRONMENT_ID=env_...
