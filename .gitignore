# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Local env files (.env.example is the only env template that should be committed)
.env
.env.local
.env.*.local

# Editor / OS noise
.DS_Store
.idea/
.vscode/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Temp files
.api-key-tmp.txt
*.tmp
*.swp

# Agent run artifacts pulled down from sessions
/packages/*.local.json

# Vercel CLI state (intentionally not committed — re-link via `vercel link` per machine)
.vercel

# Python / graphify run state
graphify-out/
__pycache__/
*.pyc
